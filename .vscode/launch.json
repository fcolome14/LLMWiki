{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Ask Vault",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": ["${input:vaultQuestion}", "--vault", "${input:vaultPath}"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ],
  "inputs": [
    {
      "id": "vaultQuestion",
      "type": "promptString",
      "description": "Question to ask about your vault notes"
    },
    {
      "id": "vaultPath",
      "type": "promptString",
      "description": "Path to the vault folder",
      "default": "vault"
    }
  ]
}